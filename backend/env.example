# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/financial_agent

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Discord Webhook (optional — all alerts go to this channel until per-user webhooks exist)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# News API Configuration
NEWS_API_KEY=your_news_api_key_here
NEWS_API_BASE_URL=https://newsapi.org/v2
NEWS_QUERY=financial OR stocks OR earnings
HOURS_BACK=24
NEWS_MAX_PAGES=3

# Application Settings
APP_NAME=Financial Research Agent
DEBUG=false
ENVIRONMENT=development

# Alert Thresholds
NEGATIVE_SENTIMENT_THRESHOLD=-0.3
POSITIVE_SENTIMENT_THRESHOLD=0.3
VOLUME_SPIKE_MULTIPLIER=2.0
ROLLING_WINDOW_DAYS=7
ALERT_COOLDOWN_HOURS=24
